{
  "name": "specwork",
  "version": "0.2.0",
  "description": "Spec-driven, test-first, graph-based workflow engine for Claude Code",
  "type": "module",
  "bin": {
    "specwork": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "workflow",
    "dag",
    "spec-driven",
    "test-first",
    "ai-agents",
    "specwork"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pupubird/specwork.git"
  },
  "homepage": "https://github.com/pupubird/specwork#readme",
  "bugs": {
    "url": "https://github.com/pupubird/specwork/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "minimatch": "^10.2.4",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
