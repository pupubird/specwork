{
  "name": "foreman",
  "version": "0.1.0",
  "description": "Spec-driven, test-first, graph-based workflow engine for Claude Code",
  "author": "pupubird",
  "license": "MIT",
  "repository": "https://github.com/pupubird/foreman",
  "skills": [
    ".claude/skills/foreman-engine/SKILL.md",
    ".claude/skills/foreman-context/SKILL.md",
    ".claude/skills/foreman-conventions/SKILL.md",
    ".claude/skills/foreman-snapshot/SKILL.md"
  ],
  "agents": [
    ".claude/agents/foreman-test-writer.md",
    ".claude/agents/foreman-implementer.md",
    ".claude/agents/foreman-verifier.md",
    ".claude/agents/foreman-summarizer.md"
  ],
  "commands": [
    ".claude/commands/foreman-plan.md",
    ".claude/commands/foreman-go.md",
    ".claude/commands/foreman-status.md"
  ],
  "hooks": {
    "SessionStart": [".claude/hooks/session-init.sh"],
    "PreToolUse": [".claude/hooks/scope-guard.sh"],
    "PostToolUse": [".claude/hooks/type-check.sh"],
    "SubagentStop": [".claude/hooks/node-complete.sh"]
  },
  "dependencies": {
    "cli": "@pupubird/foreman"
  }
}
